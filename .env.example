# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:4000

# ── Database ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=monivo
DB_USER=monivo
DB_PASSWORD=changeme
DB_SSL=false
DB_SYNC=false          # true only in dev; use migrations in prod

# ── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-256-bit-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-256-bit-random-string
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# ── AWS ──────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_KMS_KEY_ID=
AWS_SECRETS_MANAGER_PREFIX=monivo/

# ── Plaid ────────────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox           # sandbox | development | production
PLAID_WEBHOOK_URL=https://api.monivo.ai/api/v1/plaid/webhook

# ── Notifications (SES) ──────────────────────────────────────────
SES_FROM_EMAIL=noreply@monivo.ai
SES_REGION=us-east-1

# ── Rate limiting ────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── OpenTelemetry ────────────────────────────────────────────────
OTEL_SERVICE_NAME=monivo-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
